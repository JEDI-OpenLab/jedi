---
const { name, desc, url, badge, badgeType, bullets, detailed } = Astro.props;
const badgeClass = badgeType === 'gold' ? 'badge badge-gold'
  : badgeType === 'warn' ? 'badge badge-warn'
  : 'badge';
---
<article class="card">
  {badge && <span class={badgeClass}>{badge}</span>}
  <h3>{name}</h3>
  <p>{desc}</p>
  {detailed && bullets && bullets.length > 0 && (
    <ul class="card-bullets">
      {bullets.map((b) => <li>{b}</li>)}
    </ul>
  )}
  <div class="card-foot">
    <a class="card-link" href={url} target="_blank" rel="noopener">Découvrir</a>
  </div>
</article>
