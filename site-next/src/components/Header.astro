---
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/'); // garantit '/jedi/'
const path = Astro.url.pathname.replace(/\/$/, '');
const links = [
  { label: 'Projets', href: base + 'projets' },
  { label: 'Veille', href: base + 'veille' },
  { label: 'Pédagogie', href: base + 'pedagogie' },
  { label: 'À propos', href: base + 'about' },
];
const isActive = (href) => path === href.replace(/\/$/, '');
---
<header class="site-header">
  <div class="container nav">
    <a class="brand" href={base}>JEDI-OpenLab<span class="dot">.</span></a>
    <nav class="nav-links" aria-label="Navigation principale">
      {links.map((l) => (
        <a class="nav-link" href={l.href} aria-current={isActive(l.href) ? 'page' : undefined}>{l.label}</a>
      ))}
      <a class="icon-link" href="https://github.com/JEDI-OpenLab" target="_blank" rel="noopener" aria-label="JEDI-OpenLab sur GitHub" title="GitHub">
        <svg viewBox="0 0 16 16" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82A7.65 7.65 0 018 4.58c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
      </a>
      <button id="themeToggle" class="theme-toggle" type="button" aria-label="Changer de thème">◐</button>
    </nav>
  </div>
</header>

<script>
  const KEY = 'jedi_theme';
  const root = document.documentElement;
  const btn = document.getElementById('themeToggle');
  const mq = window.matchMedia('(prefers-color-scheme: dark)');
  const resolve = (p) => (p === 'dark' || (p === 'auto' && mq.matches)) ? 'dark' : 'light';
  const glyph = { auto: '◐', light: '☀', dark: '☾' };
  function apply(p) {
    root.dataset.theme = resolve(p);
    root.dataset.themePref = p;
    if (btn) {
      btn.textContent = glyph[p];
      btn.setAttribute('aria-label', `Thème : ${p}. Cliquer pour changer.`);
      btn.setAttribute('title', `Thème : ${p}`);
    }
  }
  let pref = localStorage.getItem(KEY) || 'auto';
  apply(pref);
  btn?.addEventListener('click', () => {
    pref = pref === 'auto' ? 'light' : pref === 'light' ? 'dark' : 'auto';
    localStorage.setItem(KEY, pref);
    apply(pref);
  });
  mq.addEventListener('change', () => {
    if ((localStorage.getItem(KEY) || 'auto') === 'auto') apply('auto');
  });
</script>
