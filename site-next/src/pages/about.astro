---
import Base from '../layouts/Base.astro';

const intro = [
  { k: 'Jean', t: 'Un travail de terrain, de recherche et de partage', b: 'Je m’appelle Jean. Je suis docteur en sciences de l’information et de la communication, chercheur associé en sciences de l’éducation et ingénieur pédagogique dans l’enseignement supérieur. Les contenus proposés sont mis humblement à disposition : ils ne prétendent pas clore les sujets, mais proposent des points d’appui pour apprendre, concevoir, discuter et adapter.' },
  { k: 'Mission', t: 'Aider à concevoir des dispositifs pédagogiques plus justes', b: 'JEDI-OpenLab vise à soutenir la conception, la transformation et la documentation de dispositifs de formation dans l’enseignement supérieur. Son approche privilégie l’utilité, la lisibilité, la soutenabilité et la réutilisation.' },
  { k: 'Cadre', t: 'Un travail situé dans l’enseignement supérieur', b: 'JEDI-OpenLab s’inscrit dans l’écosystème de l’enseignement supérieur et valorise une pratique de l’ingénierie pédagogique attentive aux contraintes de terrain, aux formes de mutualisation et aux usages réels.' },
];
const principes = [
  { t: 'Clarté', b: 'Rendre explicites les intentions, les choix de conception et les conditions d’usage.' },
  { t: 'Sobriété', b: 'Choisir des formats et outils proportionnés aux besoins, au temps et aux capacités de maintenance.' },
  { t: 'Ouverture', b: 'Documenter, mutualiser et favoriser la circulation des ressources et des méthodes quand cela est possible.' },
  { t: 'Exigence', b: 'Évaluer la pertinence pédagogique réelle des choix au-delà des effets de nouveauté.' },
];
---
<Base title="À propos" description="Mission, principes et positionnement de JEDI-OpenLab, porté par Jean, docteur en sciences de l’information et de la communication, chercheur associé et ingénieur pédagogique.">
  <section class="hero" style="padding-block:clamp(2.5rem,6vw,4.5rem)">
    <div class="container">
      <img src="/jedi/PIX/jedi-openlab.png" alt="JEDI-OpenLab" width="64" height="64" style="margin-bottom:1.1rem;border-radius:14px;border:1px solid var(--line);background:#fff;padding:6px" />
      <span class="eyebrow">⬡ À propos</span>
      <h1 class="display" style="font-size:clamp(2.4rem,5vw,3.6rem)">JEDI-OpenLab</h1>
      <p class="lead">JEDI signifie <strong>Jean pour l’Éducation, le Design et l’Innovation</strong>. Le projet défend une pédagogie ouverte, documentée et réutilisable, attentive aux usages réels de l’enseignement supérieur. Sa ligne éditoriale tient en une phrase : <em>Pédagogie ouverte, conçue avec soin.</em></p>
    </div>
  </section>

  <section class="section band-surface">
    <div class="container">
      <div class="grid grid-3">
        {intro.map((c) => (
          <article class="card">
            <span class="kicker" style="margin-bottom:.55rem;display:block">{c.k}</span>
            <h3>{c.t}</h3>
            <p>{c.b}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head"><span class="kicker">Repères</span><h2 class="section-title">Les principes qui structurent JEDI-OpenLab</h2></div>
      <div class="grid grid-2">
        {principes.map((p) => (
          <article class="domain"><h3 style="font-size:1.18rem;margin:0 0 .4rem">{p.t}</h3><p>{p.b}</p></article>
        ))}
      </div>
    </div>
  </section>

  <section class="section band-surface">
    <div class="container" style="max-width:880px">
      <div class="license-panel">
        <div class="license-head">
          <span class="cc-badge">CC BY 4.0</span>
          <h2 style="font-family:var(--serif);font-size:1.5rem;font-weight:600;margin:0">Ressources éducatives libres</h2>
        </div>
        <div class="prose" style="max-width:none;font-size:1.04rem">
          <p>JEDI-OpenLab s’inscrit dans l’esprit de la <a href="https://www.unesco.org/fr/legal-affairs/recommendation-open-educational-resources-oer" target="_blank" rel="noopener">Recommandation de l’UNESCO sur les ressources éducatives libres</a>, adoptée en 2019. Ce texte définit les ressources éducatives libres comme des matériels d’apprentissage, d’enseignement ou de recherche, publiés dans le domaine public ou sous licence ouverte, afin de permettre l’accès gratuit, la réutilisation, l’adaptation et la redistribution. Cette orientation rejoint directement la démarche du projet : produire des ressources pédagogiques utiles, lisibles, documentées et réutilisables, afin qu’elles puissent circuler, être discutées, adaptées à d’autres contextes, intégrées dans des formations, prolongées par d’autres personnes et améliorées collectivement.</p>
          <p>Dans cette perspective, les contenus originaux de JEDI-OpenLab sont conçus comme des ressources éducatives libres au sens de l’UNESCO et sont, sauf mention contraire, publiés sous licence <a href="https://creativecommons.org/licenses/by/4.0/deed.fr" target="_blank" rel="noopener">Creative Commons Attribution 4.0 International</a> — CC BY 4.0.</p>
          <p>Concrètement, cela signifie que les contenus, documents, exemples, fichiers web, données et ressources originales du projet peuvent être consultés, copiés, réutilisés, adaptés, traduits, modifiés, publiés et redistribués, y compris dans d’autres projets, formations ou contextes institutionnels, à condition de citer correctement l’auteur ou l’autrice, le titre de la ressource, la source et la licence.</p>
          <p>Ce choix repose sur une conviction simple : lorsqu’une ressource pédagogique peut aider, elle gagne à être disponible, modifiable et transmissible. Sa valeur ne réside pas seulement dans sa production initiale, mais aussi dans les usages, les reprises, les adaptations, les discussions et les améliorations qu’elle rend possibles.</p>
          <p style="margin-bottom:0">Les marques, logiciels, services tiers, documents sources importés dans les corpus, ressources citées et contenus appartenant à des tiers restent soumis à leurs licences et droits respectifs. Les captures d’écran, logos, images, jeux de données, modèles, polices, vidéos, sons et contenus appartenant à des tiers restent également soumis à leurs licences et droits respectifs lorsqu’ils sont indiqués.</p>
        </div>
      </div>
    </div>
  </section>
</Base>
